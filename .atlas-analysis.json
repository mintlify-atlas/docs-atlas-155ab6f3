  "keyFeatures": [
    "EVM-compatible blockchain with 5s block times and ~$0.0001 transaction fees",
    "FuseBox Wallet-as-a-Service based on ERC-4337 account abstraction",
    "Gasless transactions via Paymaster sponsorship",
    "TypeScript and Flutter/Dart SDKs for easy blockchain integration",
    "REST APIs: Smart Wallet, Balances, Trade, Notification, Explorer, Staking, GraphQL",
    "Fuse AI agentic payments infrastructure (x402, MPP, ACP, ERC-8183)",
    "Delegated Proof of Stake (DPoS) consensus with on-chain governance",
    "Charge: no-code crypto payments platform for merchants"
  ],
  "publicApiSurface": [
    "FuseSDK.init(apiKey, credentials, options)",
    "fuseSDK.wallet.getSender()",
    "fuseSDK.transferToken(tokenAddress, recipient, amount)",
    "fuseSDK.swapTokens(params)",
    "fuseSDK.transferNFT(params)",
    "fuseSDK.stakingModule.stake(params)",
    "fuseSDK.stakingModule.unstake(params)",
    "GET /v0/balances/{address}",
    "GET /v0/trade/price",
    "POST /v0/smart-wallets",
    "GET /v0/notifications",
    "GET /v1/explorer/transactions",
    "GET /v1/staking/options"
  ]
